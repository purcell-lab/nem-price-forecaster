# NEM Price Forecaster sidecar — Docker Compose environment configuration
#
# Copy this file to .env and edit before running `docker compose up -d`.
# All SIDECAR_* variables can also be set directly in the environment.
#
# Full variable reference: sidecar/app/config.py

# =============================================================================
# MINIMAL SETUP — only these two vars are required
# =============================================================================

# NEM dispatch region (QLD1, NSW1, VIC1, SA1, TAS1)
SIDECAR_REGION=QLD1

# Exact latitude/longitude of your household for Open-Meteo weather covariates.
# Defaults to the NEM-region capital city if omitted — most households are within
# 50 km and the defaults are fine for a first run.  Override for maximum accuracy.
# SIDECAR_LATITUDE=-27.47
# SIDECAR_LONGITUDE=153.03

# =============================================================================
# FINE-TUNING — all optional, defaults shown
# =============================================================================

# ---- Price model ----
# darts_naive_blend — 50/50 Darts LightGBM + seasonal-naive blend (DEFAULT)
#   Blends the two models to reduce worst-case regime-transition error.
# isotonic  — per-hour isotonic PAV calibration of PD7Day
#   Best when AEMO predispatch is accurate; poor when PD7DAY diverges.
# darts     — Darts LightGBM only, no naive blend (experimental)
# hybrid    — isotonic for the near horizon + Darts beyond (experimental)
# SIDECAR_PRICE_MODEL=darts_naive_blend

# Blend weight for darts_naive_blend: 0.5 = equal blend (evidence-based default).
# 0.0 = pure Darts; 1.0 = pure seasonal-naive. Tune after 30+ days of live data.
# SIDECAR_NAIVE_BLEND_WEIGHT=0.5

# ---- Calibrator backend (isotonic / hybrid price paths) ----
# How raw PD7DAY RRP is mapped to a realised price.
# isotonic     — 24 per-hour PAV curves (DEFAULT; shipped baseline, human-gated).
# monotone_gbm — opt-in LightGBM with a monotone constraint on the raw price +
#                cyclic hour/day-of-week features.
#                Keeps a never-lose runtime fallback to isotonic: if it does not
#                beat isotonic on a held-out tail (or LightGBM is missing) it
#                serves isotonic output, so it can only match or beat the baseline.
#                Isotonic stays the default — this is an opt-in, human-gated change.
# SIDECAR_CALIBRATOR=isotonic

# ---- Forecast window ----
# SIDECAR_FORECAST_HORIZON_HOURS=168
# SIDECAR_FORECAST_PERIOD_MINUTES=30

# ---- Tariff ----
# SIDECAR_GST_RATE=0.10
# SIDECAR_FIXED_ADDER_PER_KWH=0.0
# SIDECAR_FEED_IN_IS_WHOLESALE=true

# Time-of-Use network bands (optional). JSON array; see README Step 3 / SIDECAR_CONFIG_FILE.
# For complex ToU configs, SIDECAR_CONFIG_FILE=/data/config.json is easier than escaping JSON here.
# SIDECAR_TOU_BANDS_JSON=[]

# ---- Features ----
# SIDECAR_LOAD_FORECASTER_ENABLED=true
# SIDECAR_WEATHER_ENABLED=true

# ---- AEMO historical price seeding (Darts price model only) ----
# Downloads ~1 year of AEMO NEMWeb DISPATCHIS history on first start (cached thereafter).
# Set to 0 to disable — use only online-accumulated /calibration/import observations.
# SIDECAR_AEMO_HISTORY_DAYS=365

# ---- Scheduling ----
# SIDECAR_TRAIN_CRON=0 2 * * *
# SIDECAR_PREDICT_INTERVAL_SECONDS=300

# ---- Network ----
# SIDECAR_PORT=8765

# ---- Config file (preferred for complex setups, e.g. detailed ToU bands) ----
# If this file exists, it is loaded BEFORE env vars (env vars always win).
# SIDECAR_CONFIG_FILE=/data/config.json
